<p>
  <%= link_to 'Zurück zur Kostenübersicht', group_spendings_path %>
</p>

<h1>Kosten für <%= @group_spending.display_name %></h1>

<div class="row mb-4">
  <div class="col-md-6">
    <dl class="row mb-0">
      <dt class="col-sm-6 d-flex justify-content-between align-items-baseline">
        <span>Budget</span>
        <% if can? :update, @group_spending.group %>
          <%= link_to(@group_spending.budget.present? ? 'Bearbeiten' : 'Budget festlegen',
                      edit_group_path(@group_spending.group),
                      class: 'small') %>
        <% end %>
      </dt>
      <dd class="col-sm-6 text-end">
        <%= @group_spending.budget.present? ? euro(@group_spending.budget) : '—' %>
      </dd>
      <dt class="col-sm-6">Summe endgültig</dt>
      <dd class="col-sm-6 text-end"><%= @group_spending.final_total.positive? ? euro(@group_spending.final_total) : '—' %></dd>
      <dt class="col-sm-6">Summe gesamt (geschätzt)</dt>
      <dd class="col-sm-6 text-end"><%= @group_spending.total_estimate.positive? ? euro(@group_spending.total_estimate) : '—' %></dd>
    </dl>
  </div>
</div>

<% if @group_spending.over_budget? %>
  <div class="alert alert-danger">
    <strong>Budget überschritten:</strong>
    Die geschätzten Gesamtkosten liegen über dem Budget von <%= euro @group_spending.budget %>.
  </div>
<% elsif @group_spending.near_budget? %>
  <div class="alert alert-warning">
    <strong>Budget fast erreicht:</strong>
    Die geschätzten Gesamtkosten nähern sich dem Budget von <%= euro @group_spending.budget %>.
  </div>
<% end %>

<% if @group_spending.spending_timeline.any? %>
  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h6 card-title">Kostenverlauf</h2>
      <div style="height: 300px;"
           data-controller="group-spending-chart"
           data-group-spending-chart-timeline-value="<%= @group_spending.spending_timeline.to_json %>"
           <% if @group_spending.budget.present? %>data-group-spending-chart-budget-value="<%= @group_spending.budget %>"<% end %>>
        <canvas></canvas>
      </div>
    </div>
  </div>
<% end %>

<% if @group_spending.missing_price_article_count.positive? %>
  <div class="alert alert-danger">
    <strong>Preis fehlt:</strong>
    <%= @group_spending.missing_price_article_count %> Artikel in dieser Kochgruppe haben keinen Preis und sind unten markiert.
  </div>
<% end %>

<% if @group_spending.costs_by_box.any? %>
  <% @group_spending.costs_by_box.each do |box, article_costs| %>
    <h2 class="h5 mt-4">
      <%= link_to l(box.datetime), box %>
      <span class="badge <%= box.packed? ? 'text-bg-success' : 'text-bg-warning' %> ms-2">
        <%= box.packed? ? 'endgültig' : 'geschätzt' %>
      </span>
      <%= link_to 'Details', box_group_path(box, @group_spending.group, anchor: 'costs'), class: 'btn btn-sm btn-outline-secondary ms-2' %>
    </h2>
    <%= render 'group_box_article_costs/table', article_costs: %>
  <% end %>
<% else %>
  <p class="text-muted">Keine Kosten für diese Kochgruppe vorhanden.</p>
<% end %>
